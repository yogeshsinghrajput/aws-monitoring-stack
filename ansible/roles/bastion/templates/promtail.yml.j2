server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: "http://{{ loki_endpoint }}/loki/api/v1/push"

scrape_configs:
  # Scrape Nginx web server logs on Bastion
  - job_name: nginx
    static_configs:
      - targets:
          - localhost
        labels:
          job: nginx
          __path__: /var/log/nginx/*.log
          instance: bastion-host

  # Scrape general system logs on Bastion
  - job_name: system
    static_configs:
      - targets:
          - localhost
        labels:
          job: varlogs
          __path__: /var/log/messages
          instance: bastion-host
