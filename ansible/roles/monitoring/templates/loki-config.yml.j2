auth_enabled: false

server:
  http_listen_port: 3100
  grpc_listen_port: 9096

common:
  instance_addr: 127.0.0.1
  path_prefix: /mnt/efs/loki/{{ ansible_hostname }}
  storage:
    filesystem:
      chunks_directory: /mnt/efs/loki/{{ ansible_hostname }}/chunks
      rules_directory: /mnt/efs/loki/{{ ansible_hostname }}/rules
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

schema_config:
  configs:
    - from: 2020-10-24
      store: boltdb-shipper
      object_store: filesystem
      schema: v11
      index:
        prefix: index_
        period: 24h

limits_config:
  reject_old_samples: true
  reject_old_samples_max_age: 168h

# Enable Loki Ruler to evaluate log alerts and send them to Alertmanager
ruler:
  storage:
    type: local
    local:
      directory: /etc/loki/rules
  rule_path: /tmp/loki/rules-temp
  alertmanager_url: http://localhost:9093
  ring:
    kvstore:
      store: inmemory
